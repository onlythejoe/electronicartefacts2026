    {
      "@type": "DefinedTerm",
      "@id": "https://electronicartefacts.com/id/concept/entity-identity/",
      "identifier": "ea:concept:entity-identity",
      "name": "Entity Identity",
      "abstract": "Entity identity gives knowledge systems a way to cite things without confusing names, pages, files, versions and changing descriptions.",
      "description": "Entity identity is the durable naming of a person, concept, project, program, publication or artefact so that references remain stable as descriptions evolve.",
