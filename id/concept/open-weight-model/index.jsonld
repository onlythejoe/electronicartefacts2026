      "@type": "DefinedTerm",
      "@id": "https://electronicartefacts.com/id/concept/open-weight-model/",
      "identifier": "ea:concept:open-weight-model",
      "name": "Open-Weight Model",
      "abstract": "Open-weight models enable local inference and adaptation but must be distinguished from fully open-source AI systems.",
      "description": "An open-weight model is a machine-learning model whose learned parameters are distributed for reuse under stated terms, without necessarily providing the training data, training code or freedoms required by open-source definitions.",
      "url": "https://electronicartefacts.com/knowledge/concepts/open-weight-model/",
