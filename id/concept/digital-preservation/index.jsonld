      "@type": "DefinedTerm",
      "@id": "https://electronicartefacts.com/id/concept/digital-preservation/",
      "identifier": "ea:concept:digital-preservation",
      "name": "Digital Preservation",
      "abstract": "Digital preservation connects file formats, metadata, provenance, storage, rights, migration and interpretation into a long-term care practice for digital culture.",
      "description": "Digital preservation is the long-term work of keeping digital objects understandable, authentic, usable and accessible despite changes in formats, software, hardware and context.",
