      "identifier": "ea:concept:graph-modeling",
      "name": "Graph Modeling",
      "abstract": "Graph modeling makes many-to-many relationships, paths, provenance and evolving context explicit where folders and rigid trees obscure them.",
      "description": "Graph modeling represents a domain through addressable nodes, typed relationships and properties chosen to answer specific questions and support specific operations.",
