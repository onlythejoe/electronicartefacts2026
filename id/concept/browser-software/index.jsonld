      "@type": "DefinedTerm",
      "@id": "https://electronicartefacts.com/id/concept/browser-software/",
      "identifier": "ea:concept:browser-software",
      "name": "Browser Software",
      "abstract": "Browser software treats the web browser as an application runtime, not only as a document viewer or marketing surface.",
      "description": "Browser software is application software delivered through web standards while relying on the browser runtime for interface, storage, permissions, media and distribution behavior.",
